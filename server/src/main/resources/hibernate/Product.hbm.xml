<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.tm.nc.domain.product.model.Product" table="products">

        <id name="id" column="id">
            <generator class="sequence"/>
        </id>

        <property name="name" column="name" not-null="true"/>
        <property name="model" column="model" not-null="true"/>

        <many-to-one name="brand"
                     class="com.tm.nc.domain.brand.model.Brand"
                     column="brand_id"
                     not-null="true"
                     cascade="all"/>

        <bag name="colors" cascade="all">
            <key column="product_id"/>
            <one-to-many class="com.tm.nc.domain.product.model.Color"/>
        </bag>

    </class>

</hibernate-mapping>