<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.tm.nc.domain.cart.model.Cart" table="carts">

        <id name="id" column="id">
            <generator class="sequence"/>
        </id>

        <bag name="items" cascade="all" lazy="false">
            <key column="cart_id"/>
            <one-to-many class="com.tm.nc.domain.cart.model.ItemCart"/>
        </bag>

    </class>

</hibernate-mapping>