<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.tm.nc.domain.productDetail.model.ProductDetail" table="product_details">

        <id name="id" column="id">
            <generator class="sequence"/>
        </id>

        <property name="size" column="size" not-null="true"/>
        <property name="price" column="price" not-null="true"/>

        <property name="quantity" column="quantity" not-null="true"/>

        <many-to-one name="color"
                     lazy="false"
                     class="com.tm.nc.domain.color.model.Color"
                     column="color_id"/>


    </class>

</hibernate-mapping>
