<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">

<hibernate-mapping>

    <class name="com.tm.nc.domain.cart.model.ItemCart" table="items_cart">

        <id name="id" column="id">
            <generator class="sequence"/>
        </id>

        <many-to-one name="color"
                     class="com.tm.nc.domain.color.model.Color"
                     column="color_id"
                     not-null="true"/>

        <many-to-one name="productDetail"
                     class="com.tm.nc.domain.productDetail.model.ProductDetail"
                     column="product_detail_id"
                     not-null="true"/>

        <property name="quantity" column="quantity" not-null="true"/>

    </class>

</hibernate-mapping>